# Database
DATABASE_URL=postgres://resume:password@localhost:5432/resume

# Auth (GitHub OAuth via Auth.js v5)
# 1. Create a GitHub OAuth App at https://github.com/settings/developers
# 2. Set callback URL to http://localhost:3004/api/auth/callback/github (dev)
# 3. Copy Client ID and generate a Client Secret
AUTH_SECRET=                          # openssl rand -base64 32
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_GITHUB_ID=                      # numeric ID — run: curl -s https://api.github.com/users/YOUR_USERNAME | jq .id
